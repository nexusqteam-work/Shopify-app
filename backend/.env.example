# ═══════════════════════════════════════════
#  StoreCoach — Environment Variables
#  Copy this to .env and fill in values
# ═══════════════════════════════════════════

# ── Server ──────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=https://your-app.railway.app
FRONTEND_URL=https://your-frontend.vercel.app

# ── Database (PostgreSQL) ───────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/storecoach

# ── Redis (for job queues) ──────────────────
REDIS_URL=redis://localhost:6379

# ── Shopify App Credentials ─────────────────
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,read_orders,read_customers,read_analytics,read_inventory,read_script_tags,write_script_tags
SHOPIFY_HOST_NAME=your-app.railway.app

# ── Anthropic (Claude AI) ───────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── JWT Auth ─────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# ── Encryption (for storing access tokens) ──
ENCRYPTION_KEY=your-32-char-encryption-key-here

# ── Email (Nodemailer) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=StoreCoach <noreply@storecoach.app>

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Google PageSpeed API (optional but recommended) ──
PAGESPEED_API_KEY=your_google_pagespeed_api_key

# ── Puppeteer (auto-set by Dockerfile on Railway) ──
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
